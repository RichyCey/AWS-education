# Terraform state (contains secrets in plaintext)
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Variable files that may contain sensitive values
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# IDE
.vscode/
.idea/

# Lambda build artifacts
lambda/*.zip
lambda/layer/
